{
  "name": "acmegrade-ecommerce-project",
  "version": "1.0.0",
  "description": "Full stack e-commerce project with admin and client modules for internship submission.",
  "main": "server.js",
  "scripts": {
    "build": "esbuild ./frontend/src/main.jsx --bundle --minify --outfile=./public/app.js --loader:.jsx=jsx",
    "build:watch": "esbuild ./frontend/src/main.jsx --bundle --outfile=./public/app.js --loader:.jsx=jsx --watch",
    "prestart": "npm run build",
    "start": "node server.js",
    "test": "node scripts/smoke-test.js"
  },
  "keywords": [
    "ecommerce",
    "full-stack",
    "nodejs"
  ],
  "author": "Jeel Gohel",
  "license": "MIT",
  "dependencies": {
    "esbuild": "^0.28.1",
    "mongodb": "^7.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
